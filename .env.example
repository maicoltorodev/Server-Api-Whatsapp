# ==========================================
# PET CARE STUDIO BACKEND (.env.example)
# ==========================================

# 1. Configuración del Servidor Express
PORT=3000
TIMEZONE="America/Bogota"

# 2. Configuración de Meta (WhatsApp Business API)
# Obtener desde: https://developers.facebook.com/apps/
PHONE_NUMBER_ID="tu_phone_number_id_aqui"
WHATSAPP_TOKEN="tu_token_permanente_o_temporal_aqui"
VERIFY_TOKEN="tu_token_inventado_para_el_webhook"
META_APP_SECRET="tu_app_secret_aqui"

# 4. Configuración Inteligencia Artificial (Google Gemini)
# Obtener desde: https://aistudio.google.com/
GEMINI_API_KEY="tu_api_key_gemini_1.5_flash_aqui"

# 5. Base de Datos (Supabase)
# Obtener desde las configuraciones del proyecto en Supabase
SUPABASE_URL="https://tu-id-proyecto.supabase.co"
SUPABASE_KEY="tu_anon_key_o_service_role_key_aqui"

# 6. Seguridad Interna
# Clave maestra para que el Frontend pueda hacer POST al Backend y refrescar la caché
ADMIN_API_KEY="super_secret_admin_key_123_cambiar_en_produccion"
# URL del frontend autorizado para llamadas a la API (CORS)
FRONTEND_URL="http://localhost:3000"
